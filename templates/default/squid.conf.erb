# This file generated from a Chef template.
# squid/templates/default.squid.conf.erb

<% if @enable_ldap %>
auth_param basic program <%= @ldap_program %> -v <%= @ldap_version %> -b <%= @ldap_basedn %> <%= "-D #{@ldap_binddn}" unless @ldap_binddn.nil? %> <%= "-w #{@ldap_bindpassword}" unless @ldap_bindpassword.nil? %> -f <%= @ldap_searchfilter %> <%= @ldap_host %>
auth_param basic children <%= @ldap_authchildren %>
auth_param basic realm <%= @ldap_authrealm %>
auth_param basic credentialsttl <%= @ldap_authcredentialsttl %>
<% end %>

<% if @cache_peer %>
    <%= @cache_peer %>
<% end %>

<%= "acl all src" if @version.to_i < 3 %>
<%= "acl manager proto cache_object" if @version.to_f < 3.2 %>
<%= "acl localhost src 127.0.0.1/32" if @version.to_f < 3.2 %>
<%= "acl to_localhost dst 127.0.0.0/8 0.0.0.0/32" if @version.to_f < 3.2 %>
<% @localnets.each do |localnet| %>
acl localnet src <%= localnet %>
<% end %>

<% @ssl_ports.each do |port| %>
acl SSL_ports port <%= port %>
<% end %>
<% @safe_ports.each do |port| %>
acl Safe_ports port <%= port %>
<% end %>
acl purge method PURGE
acl CONNECT method CONNECT

# Managed with Chef
<% @host_acl.each do |host| %>
acl <%= host[0] %> <%= host[1] %> <%= host[2] %>
<% end %>
<% @url_acl.each do |url| %>
acl <%= url[0] %> <%= url[1] %> <%= url[2] %>
<% end %>
<% @acls.each do |acl| %>
http_access <%= acl[0] %> <%= acl[1] %> <%= acl[2] %>
<% end %>

http_access allow manager localhost
http_access deny manager
http_access allow purge localhost
http_access deny purge
<% if @enable_safe_ports_restriction -%>
http_access deny !Safe_ports
<% end -%>
<% if @enable_connect_restriction -%>
http_access deny CONNECT !SSL_ports
<% end -%>
http_access allow localhost
<%= "http_access allow localnet" if !@localnets.empty? %>
<%= "http_access deny all" if @http_access_deny_all %>

<%= "icp_access allow localnet" if !@localnets.empty? %>
<%= "icp_access deny all" if @icp_access_deny_all %>
<% if @port.kind_of?(Array) %>
  <% @port.each do |port| %>
http_port <%= port %>
  <% end %>
<% else %>
http_port <%= @port %>
<% end %>

<%= "hierarchy_stoplist cgi-bin ?" if @version.to_f < 3.5 %>

<% @logformats.each do |name, format| %>
logformat <%= name %> <%= format %>
<% end -%>

access_log <%= !@log_module.nil? ? @log_module + ':' : '' %><%= @log_dir %>/access.log <%= @access_log_option %>
refresh_pattern	    ^ftp:			1440	20%	10080
refresh_pattern     ^gopher:			1440	0%	1440
refresh_pattern	    -i (/cgi-bin/|\?)		0	0%	0
refresh_pattern     (Release|Package(.gz)*)$	0	20%	2880
# refresh_pattern	    \.deb$			1440    20%	10080
# refresh_pattern	    \.rpm$			1440    20%	10080
# refresh_pattern	    \.iso$			1440    20%	10080
# refresh_pattern	    \.$			1440    20%	10080
# refresh_pattern	    .				0	20%	4320
hosts_file /etc/hosts
maximum_object_size <%= @max_obj_size %> <%= @max_obj_size_unit %>
<%- if @enable_cache_dir %>
cache_dir ufs <%= @cache_dir %> <%= @cache_size %> 16 256
<%- end %>
coredump_dir <%= @coredump_dir %>
cache_mem <%= @cache_mem %> MB
<% @directives.each do |directive| %>
<%= directive %>
<% end %>

<% if @config_include_dir %>
# Include additional configuration files
include <%= @config_include_dir %>/*.conf
<% end %>
